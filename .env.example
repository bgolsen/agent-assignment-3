# Copy this file to .env and fill in values.
#   cp .env.example .env

# ---- Timezone --------------------------------------------------------------
# IANA tz name. Affects Schedule trigger nodes and timestamps.
GENERIC_TIMEZONE=America/Los_Angeles

# ---- Encryption key (REQUIRED) ---------------------------------------------
# Used to encrypt stored credentials in the SQLite DB.
# Generate one with:   openssl rand -hex 32
# Keep this value stable across restarts or your saved credentials will break.
N8N_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# ---- Editor UI auth (optional) ---------------------------------------------
# Off by default for local development. Set ACTIVE=true and pick a user/pass
# if you expose n8n beyond localhost.
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ---- LLM API keys for AI nodes ---------------------------------------------
# Picked up automatically by n8n's OpenAI / Anthropic / LangChain nodes.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
